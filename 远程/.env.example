# 对外访问域名，不要填写 http:// 或路径。
DOMAIN=crm.example.com
ACME_EMAIL=admin@example.com

# MySQL 仅供容器内部使用。请分别生成高强度随机密码，避免使用特殊字符 @ : / # %。
MYSQL_DATABASE=consulting_requirement
MYSQL_USER=crm_app
MYSQL_PASSWORD=replace_with_a_long_random_password
MYSQL_ROOT_PASSWORD=replace_with_another_long_random_password

# 仅空库首次启动时创建的管理员。首次登录后系统强制修改临时密码。
# 初始化成功后不要再修改 ADMIN_USERNAME；确认已改密并建立第二管理员后可保留变量名并把值留空。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_initial_password

SESSION_HOURS=12
MAX_LOGIN_FAILURES=5
LOCK_MINUTES=15
MAX_UPLOAD_MB=50
